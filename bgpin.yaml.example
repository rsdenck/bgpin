# bgpin Configuration File
# Copy this file to bgpin.yaml and customize as needed

# General settings
timeout: 30  # Default timeout in seconds
output: table  # Default output format: table, json, yaml

# Cache configuration
cache:
  enabled: true
  ttl: 300  # Time to live in seconds (5 minutes)

# Flow collection configuration
flow:
  enabled: false  # Enable flow collection
  
  # NetFlow configuration
  netflow:
    enabled: true
    addr: "0.0.0.0"
    port: 2055
  
  # sFlow configuration
  sflow:
    enabled: true
    addr: "0.0.0.0"
    port: 6343
  
  # IPFIX configuration
  ipfix:
    enabled: true
    addr: "0.0.0.0"
    port: 4739
  
  # Processing configuration
  workers: 4  # Number of flow processing workers
  buffer_size: 10000  # Flow buffer size
  bgp_correlation: true  # Enable BGP correlation
  
  # Aggregation settings
  aggregate_window: 60  # Aggregation window in seconds
  max_flows: 100000  # Maximum flows to keep in memory
  
  # Anomaly detection
  anomaly_detection: true
  anomaly_window: 300  # Anomaly detection window in seconds

# Looking Glass configurations
looking_glasses:
  - name: "RIPE RIS"
    url: "https://stat.ripe.net"
    vendor: "ripe"
    type: "http"
    enabled: true

  - name: "Hurricane Electric"
    url: "https://lg.he.net"
    vendor: "cisco"
    type: "http"
    enabled: false

  - name: "Level3"
    url: "https://lookingglass.centurylink.com"
    vendor: "cisco"
    type: "http"
    enabled: false

# RIPE RIS SDK Configuration
ripe:
  rate_limit: 10  # Requests per second
  retry_max: 3
  retry_wait_min: 1  # seconds
  retry_wait_max: 10  # seconds
  user_agent: "bgpin/0.1.0"

# SNMP Configuration
snmp:
  default_community: "public"
  default_version: "2c"
  default_port: 161
  default_timeout: 5
  default_retries: 3
  
  # Dispositivos pré-configurados
  devices:
    # ArmazemDC Routers
    rt-jlle01:
      host: "10.21.10.254"
      community: "RT-ADC-JL-01-MGT"
      version: "2c"
      description: "ArmazemDC Router JL01"
    
    rt-jlle02:
      host: "10.21.10.253"
      community: "RT-ADC-JL-02-MGT"
      version: "2c"
      description: "ArmazemDC Router JL02"
      
    # Exemplos genéricos
    router-core:
      host: "192.168.1.1"
      community: "bgp-monitoring"
      version: "2c"
      description: "Core Router"
    
    switch-access:
      host: "192.168.1.10"
      community: "network-ops"
      version: "2c"
      description: "Access Switch"

# Analysis settings
analysis:
  # Detect AS-PATH prepending
  max_prepend: 3  # Alert if same ASN appears more than this many times
  
  # Detect suspicious AS-PATH patterns
  check_loops: true
  check_bogon_asns: true
  
  # RPKI validation
  rpki_enabled: false
  rpki_server: ""

# Output settings
output_settings:
  # Table format settings
  table:
    max_rows: 50
    truncate: true
  
  # JSON format settings
  json:
    pretty: true
    indent: 2
  
  # YAML format settings
  yaml:
    indent: 2

# Logging
logging:
  level: "info"  # debug, info, warn, error
  format: "text"  # text, json
  output: "stderr"  # stdout, stderr, file path
